# ─── Server Environment Variables ────────────────────────────────────────────

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/syncsphere

# JWT signing secret (keep this long and random!)
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# URL of the client (used to build invite links)
CLIENT_URL=http://localhost:5173

# ─── Email (needed for "Send via Email" on the invite page) ──────────────────
# Use a Gmail account + App Password (NOT your regular Gmail password)
# To create an App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here
